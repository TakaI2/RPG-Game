{
  "assets": {
    "bgm": [
      { "key": "spiral",  "url": "assets/story/bgm/spiral.ogg" },
      { "key": "redmoon", "url": "assets/story/bgm/redmoon.ogg" }
    ]
  },
  "start": {
    "story": "intro",
    "then": { "action": "goto_map", "mapId": "demo_map", "x": 10, "y": 10 }
  },
  "maps": {
    "demo_map": {
      "bgm": "spiral",
      "onEnter": null,
      "boss": null,
      "onPlayerDefeat": { "story": "gameover", "then": { "action": "exit" } },
      "eventTriggers": [
        {
          "x": 50,
          "y": 45,
          "type": "story",
          "storyId": "priest_event",
          "once": true,
          "marker": true,
          "then": { "action": "stay" }
        }
      ],
      "portals": [
        { "targetMap": "boss_map", "targetX": 25, "targetY": 8 }
      ]
    },
    "boss_map": {
      "bgm": "redmoon",
      "onEnter": null,
      "boss": { "configKey": "volg_boss", "x": 25, "y": 25 },
      "onPlayerDefeat": { "story": "gameover", "then": { "action": "exit" } },
      "onBossDefeat": { "story": "clear", "then": { "action": "exit" } },
      "eventTriggers": [],
      "portals": [
        { "targetMap": "demo_map", "targetX": 50, "targetY": 46 }
      ]
    }
  }
}
