{
  "start": {
    "story": "intro",
    "then": { "action": "goto_map", "mapId": "demo_map", "x": 10, "y": 10 }
  },
  "maps": {
    "demo_map": {
      "onEnter": null,
      "hasBoss": false,
      "onPlayerDefeat": { "story": "gameover", "then": { "action": "exit" } },
      "eventTriggers": [
        {
          "x": 50,
          "y": 45,
          "type": "story",
          "storyId": "priest_event",
          "once": true,
          "marker": true,
          "then": { "action": "stay" }
        },
        {
          "x": 55,
          "y": 45,
          "type": "teleport",
          "targetMap": "boss_map",
          "targetX": 25,
          "targetY": 8,
          "once": false,
          "marker": true,
          "markerColor": "green"
        }
      ]
    },
    "boss_map": {
      "onEnter": null,
      "hasBoss": true,
      "onPlayerDefeat": { "story": "gameover", "then": { "action": "exit" } },
      "onBossDefeat": { "story": "clear", "then": { "action": "exit" } },
      "eventTriggers": [
        {
          "x": 25,
          "y": 11,
          "type": "teleport",
          "targetMap": "demo_map",
          "targetX": 50,
          "targetY": 46,
          "once": false,
          "marker": true,
          "markerColor": "green"
        }
      ]
    }
  }
}
